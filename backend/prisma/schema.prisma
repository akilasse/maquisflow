// ============================================================
// Flowix - Schéma de base de données
// ORM : Prisma v5 | Base : MySQL / MariaDB
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           Int      @id @default(autoincrement())
  nom          String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  mot_de_passe String   @db.VarChar(255)
  actif        Boolean  @default(true)
  created_at   DateTime @default(now())
}

model Maquis {
  id                      Int        @id @default(autoincrement())
  nom                     String     @db.VarChar(100)
  type                    TypeMaquis @default(maquis)
  activite                String?    @db.VarChar(100)
  logo_url                String?    @db.VarChar(255)
  couleur_primaire        String?    @db.VarChar(7)
  devise                  String     @default("XOF") @db.VarChar(10)
  fuseau_horaire          String     @default("Africa/Abidjan") @db.VarChar(50)
  actif                   Boolean    @default(true)
  module_commandes_actif  Boolean    @default(false)
  paiement_avant          Boolean    @default(false)
  created_at              DateTime   @default(now())

  utilisateurs    UtilisateurMaquis[]
  produits        Produit[]
  ventes          Vente[]
  mouvements      StockMouvement[]
  inventaires     Inventaire[]
  logs            LogAction[]
  fournisseurs    Fournisseur[]
  bons_livraison  BonLivraison[]
  abonnement      Abonnement?
  stations        Station[]
  tables          TableEtablissement[]
  commandes       Commande[]
}

enum TypeMaquis {
  maquis
  restaurant
}

model Abonnement {
  id              Int              @id @default(autoincrement())
  maquis_id       Int              @unique
  maquis          Maquis           @relation(fields: [maquis_id], references: [id])
  type_acces      TypeAcces        @default(abonnement)
  periodicite     Periodicite?
  montant         Decimal          @default(35000) @db.Decimal(10,2)
  statut          StatutAbonnement @default(essai)
  bloque          Boolean          @default(false)
  date_debut      DateTime         @default(now())
  date_echeance   DateTime?
  date_paiement   DateTime?
  mode_paiement   String?          @db.VarChar(50)
  reference       String?          @db.VarChar(100)
  note            String?          @db.Text
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
}

enum TypeAcces {
  achat_unique
  abonnement
}

enum Periodicite {
  mensuel
  annuel
}

enum StatutAbonnement {
  actif
  expire
  suspendu
  essai
}

model UtilisateurMaquis {
  id             Int         @id @default(autoincrement())
  utilisateur_id Int
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id])
  maquis_id      Int
  maquis         Maquis      @relation(fields: [maquis_id], references: [id])
  role           Role        @default(caissier)
  actif          Boolean     @default(true)
  created_at     DateTime    @default(now())
  @@unique([utilisateur_id, maquis_id])
}

model Utilisateur {
  id           Int       @id @default(autoincrement())
  nom          String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  mot_de_passe String    @db.VarChar(255)
  photo_url    String?   @db.VarChar(255)
  actif        Boolean   @default(true)
  created_at   DateTime  @default(now())

  etablissements UtilisateurMaquis[]
  ventes         Vente[]
  mouvements     StockMouvement[]
  logs           LogAction[]
  commandes      Commande[]
}

enum Role {
  caissier
  gerant
  patron
  serveur
}

model Produit {
  id               Int       @id @default(autoincrement())
  maquis_id        Int
  maquis           Maquis    @relation(fields: [maquis_id], references: [id])
  nom              String    @db.VarChar(150)
  categorie        String?   @db.VarChar(80)
  prix_vente       Decimal   @db.Decimal(10,2)
  prix_achat       Decimal   @db.Decimal(10,2)
  stock_actuel     Decimal   @db.Decimal(10,3)
  stock_min        Decimal   @default(0) @db.Decimal(10,3)
  unite            String    @default("unité") @db.VarChar(20)
  photo_url        String?   @db.VarChar(255)
  code_barre       String?   @db.VarChar(100)
  actif            Boolean   @default(true)
  station_id       Int?
  station          Station?  @relation(fields: [station_id], references: [id])

  lignes           VenteLigne[]
  mouvements       StockMouvement[]
  inventaires      InventaireLigne[]
  lignes_livraison BonLivraisonLigne[]
  lignes_commande  CommandeLigne[]
}

model Vente {
  id             Int          @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis       @relation(fields: [maquis_id], references: [id])
  caissier_id    Int
  caissier       Utilisateur  @relation(fields: [caissier_id], references: [id])
  date_vente     DateTime     @default(now())
  total_brut     Decimal      @db.Decimal(10,2)
  remise_globale Decimal      @default(0) @db.Decimal(5,2)
  total_net      Decimal      @db.Decimal(10,2)
  mode_paiement  ModePaiement
  statut         StatutVente  @default(validee)
  valide_par     Int?
  note           String?      @db.Text
  commande_id    Int?         @unique

  lignes   VenteLigne[]
  commande Commande?    @relation(fields: [commande_id], references: [id])
}

enum ModePaiement {
  especes
  wave
  orange_money
  mtn_money
  credit
  autre
}

enum StatutVente {
  validee
  annulee
  credit_en_cours
}

model VenteLigne {
  id              Int     @id @default(autoincrement())
  vente_id        Int
  vente           Vente   @relation(fields: [vente_id], references: [id])
  produit_id      Int
  produit         Produit @relation(fields: [produit_id], references: [id])
  quantite        Decimal @db.Decimal(10,3)
  prix_unitaire   Decimal @db.Decimal(10,2)
  prix_catalogue  Decimal @db.Decimal(10,2)
  economie_client Decimal @default(0) @db.Decimal(10,2)
  remise_ligne    Decimal @default(0) @db.Decimal(5,2)
  total_ligne     Decimal @db.Decimal(10,2)
}

model StockMouvement {
  id             Int           @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis        @relation(fields: [maquis_id], references: [id])
  produit_id     Int
  produit        Produit       @relation(fields: [produit_id], references: [id])
  type_mouvement TypeMouvement
  quantite       Decimal       @db.Decimal(10,3)
  raison         String?       @db.VarChar(255)
  utilisateur_id Int
  utilisateur    Utilisateur   @relation(fields: [utilisateur_id], references: [id])
  date_mouvement DateTime      @default(now())
  valide_par     Int?
  valide_at      DateTime?
  fournisseur_id Int?
  fournisseur    Fournisseur?  @relation(fields: [fournisseur_id], references: [id])
}

enum TypeMouvement {
  entree
  sortie_vente
  sortie_manuelle
  ajustement
}

model Inventaire {
  id          Int              @id @default(autoincrement())
  maquis_id   Int
  maquis      Maquis           @relation(fields: [maquis_id], references: [id])
  date_debut  DateTime         @default(now())
  date_fin    DateTime?
  statut      StatutInventaire @default(en_cours)
  cree_par    Int
  cloture_par Int?
  lignes      InventaireLigne[]
}

enum StatutInventaire {
  en_cours
  cloture
}

model InventaireLigne {
  id            Int        @id @default(autoincrement())
  inventaire_id Int
  inventaire    Inventaire @relation(fields: [inventaire_id], references: [id])
  produit_id    Int
  produit       Produit    @relation(fields: [produit_id], references: [id])
  qte_theorique Decimal    @db.Decimal(10,3)
  qte_reelle    Decimal    @db.Decimal(10,3)
  ecart         Decimal    @db.Decimal(10,3)
}

model LogAction {
  id             Int         @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis      @relation(fields: [maquis_id], references: [id])
  utilisateur_id Int
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id])
  type_action    String      @db.VarChar(80)
  description    String?     @db.Text
  date_action    DateTime    @default(now())
  ip_client      String?     @db.VarChar(45)
}

model Fournisseur {
  id             Int              @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis           @relation(fields: [maquis_id], references: [id])
  nom            String           @db.VarChar(150)
  telephone      String?          @db.VarChar(20)
  email          String?          @db.VarChar(150)
  adresse        String?          @db.VarChar(255)
  actif          Boolean          @default(true)
  created_at     DateTime         @default(now())
  mouvements     StockMouvement[]
  bons_livraison BonLivraison[]
}

model BonLivraison {
  id             Int                @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis             @relation(fields: [maquis_id], references: [id])
  fournisseur_id Int?
  fournisseur    Fournisseur?       @relation(fields: [fournisseur_id], references: [id])
  date_livraison DateTime           @default(now())
  note           String?            @db.Text
  total_achat    Decimal            @db.Decimal(10,2)
  cree_par       Int
  lignes         BonLivraisonLigne[]
}

model BonLivraisonLigne {
  id          Int          @id @default(autoincrement())
  bon_id      Int
  bon         BonLivraison @relation(fields: [bon_id], references: [id])
  produit_id  Int
  produit     Produit      @relation(fields: [produit_id], references: [id])
  quantite    Decimal      @db.Decimal(10,3)
  prix_achat  Decimal      @db.Decimal(10,2)
  total_ligne Decimal      @db.Decimal(10,2)
}

// ============================================================
// MODULE COMMANDES — Restaurant / Fast Food
// ============================================================

model Station {
  id        Int     @id @default(autoincrement())
  maquis_id Int
  maquis    Maquis  @relation(fields: [maquis_id], references: [id])
  nom       String  @db.VarChar(80)
  couleur   String  @default("#6b7280") @db.VarChar(7)
  actif     Boolean @default(true)

  produits         Produit[]
  lignes_commande  CommandeLigne[]
}

model TableEtablissement {
  id        Int         @id @default(autoincrement())
  maquis_id Int
  maquis    Maquis      @relation(fields: [maquis_id], references: [id])
  numero    Int
  nom       String?     @db.VarChar(80)
  capacite  Int?
  statut    StatutTable @default(libre)
  actif     Boolean     @default(true)

  commandes Commande[]

  @@unique([maquis_id, numero])
}

enum StatutTable {
  libre
  occupee
  reservee
}

model Commande {
  id            Int            @id @default(autoincrement())
  maquis_id     Int
  maquis        Maquis         @relation(fields: [maquis_id], references: [id])
  table_id      Int?
  table         TableEtablissement? @relation(fields: [table_id], references: [id])
  serveur_id    Int?
  serveur       Utilisateur?   @relation(fields: [serveur_id], references: [id])
  type_commande TypeCommande   @default(sur_place)
  statut        StatutCommande @default(ouverte)
  numero             Int
  note               String?  @db.Text
  temps_preparation  Int?
  created_at         DateTime @default(now())
  updated_at    DateTime       @updatedAt

  lignes CommandeLigne[]
  vente  Vente?

  @@unique([maquis_id, numero])
}

enum TypeCommande {
  sur_place
  comptoir
  emporter
}

enum StatutCommande {
  ouverte
  en_cours
  prete
  servie
  encaissee
  annulee
}

model CommandeLigne {
  id            Int         @id @default(autoincrement())
  commande_id   Int
  commande      Commande    @relation(fields: [commande_id], references: [id])
  produit_id    Int
  produit       Produit     @relation(fields: [produit_id], references: [id])
  station_id    Int?
  station       Station?    @relation(fields: [station_id], references: [id])
  quantite      Decimal     @db.Decimal(10,3)
  prix_unitaire Decimal     @db.Decimal(10,2)
  note          String?     @db.VarChar(255)
  statut        StatutLigne @default(en_attente)
  created_at    DateTime    @default(now())
}

enum StatutLigne {
  en_attente
  en_preparation
  prete
  servie
  annulee
}
