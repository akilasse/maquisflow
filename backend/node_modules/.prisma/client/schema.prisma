// ============================================================
// MAQUISFLOW - Schéma de base de données
// ORM : Prisma v5 | Base : MySQL / MariaDB
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// SUPER ADMIN
// ------------------------------------------------------------
model SuperAdmin {
  id           Int      @id @default(autoincrement())
  nom          String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  mot_de_passe String   @db.VarChar(255)
  actif        Boolean  @default(true)
  created_at   DateTime @default(now())
}

// ------------------------------------------------------------
// MAQUIS
// ------------------------------------------------------------
model Maquis {
  id               Int                 @id @default(autoincrement())
  nom              String              @db.VarChar(100)
  type             TypeMaquis          @default(maquis)
  logo_url         String?             @db.VarChar(255)
  couleur_primaire String?             @db.VarChar(7)
  devise           String              @default("XOF") @db.VarChar(10)
  fuseau_horaire   String              @default("Africa/Abidjan") @db.VarChar(50)
  actif            Boolean             @default(true)
  created_at       DateTime            @default(now())
  // Relations
  utilisateurs     UtilisateurMaquis[]
  produits         Produit[]
  ventes           Vente[]
  mouvements       StockMouvement[]
  inventaires      Inventaire[]
  logs             LogAction[]
  fournisseurs     Fournisseur[]
  bons_livraison   BonLivraison[]
  abonnement       Abonnement?
}

enum TypeMaquis {
  maquis
  restaurant
}

// ------------------------------------------------------------
// ABONNEMENT
// type_acces : achat_unique (permanent) | abonnement (mensuel/annuel)
// periodicite : mensuel | annuel (null si achat_unique)
// date_echeance : null si achat_unique (accès permanent)
// bloque : true si abonnement expiré → déconnexion automatique
// ------------------------------------------------------------
model Abonnement {
  id            Int              @id @default(autoincrement())
  maquis_id     Int              @unique
  maquis        Maquis           @relation(fields: [maquis_id], references: [id])
  type_acces    TypeAcces        @default(abonnement)
  periodicite   Periodicite? // null si achat_unique
  montant       Decimal          @default(35000) @db.Decimal(10, 2)
  statut        StatutAbonnement @default(essai)
  bloque        Boolean          @default(false) // true = déconnexion forcée
  date_debut    DateTime         @default(now())
  date_echeance DateTime? // null si achat_unique
  date_paiement DateTime?
  mode_paiement String?          @db.VarChar(50)
  reference     String?          @db.VarChar(100)
  note          String?          @db.Text
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
}

enum TypeAcces {
  achat_unique // Paiement unique, accès permanent
  abonnement // Récurrent mensuel ou annuel
}

enum Periodicite {
  mensuel
  annuel
}

enum StatutAbonnement {
  actif
  expire
  suspendu
  essai
}

// ------------------------------------------------------------
// UTILISATEUR MAQUIS
// ------------------------------------------------------------
model UtilisateurMaquis {
  id             Int         @id @default(autoincrement())
  utilisateur_id Int
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id])
  maquis_id      Int
  maquis         Maquis      @relation(fields: [maquis_id], references: [id])
  role           Role        @default(caissier)
  actif          Boolean     @default(true)
  created_at     DateTime    @default(now())

  @@unique([utilisateur_id, maquis_id])
}

// ------------------------------------------------------------
// UTILISATEUR
// ------------------------------------------------------------
model Utilisateur {
  id             Int                 @id @default(autoincrement())
  nom            String              @db.VarChar(100)
  email          String              @unique @db.VarChar(150)
  mot_de_passe   String              @db.VarChar(255)
  actif          Boolean             @default(true)
  created_at     DateTime            @default(now())
  // Relations
  etablissements UtilisateurMaquis[]
  ventes         Vente[]
  mouvements     StockMouvement[]
  logs           LogAction[]
}

enum Role {
  caissier
  gerant
  patron
}

// ------------------------------------------------------------
// PRODUIT
// ------------------------------------------------------------
model Produit {
  id               Int                 @id @default(autoincrement())
  maquis_id        Int
  maquis           Maquis              @relation(fields: [maquis_id], references: [id])
  nom              String              @db.VarChar(150)
  categorie        String?             @db.VarChar(80)
  prix_vente       Decimal             @db.Decimal(10, 2)
  prix_achat       Decimal             @db.Decimal(10, 2)
  stock_actuel     Decimal             @db.Decimal(10, 3)
  stock_min        Decimal             @default(0) @db.Decimal(10, 3)
  unite            String              @default("unité") @db.VarChar(20)
  actif            Boolean             @default(true)
  lignes           VenteLigne[]
  mouvements       StockMouvement[]
  inventaires      InventaireLigne[]
  lignes_livraison BonLivraisonLigne[]
}

// ------------------------------------------------------------
// VENTE
// ------------------------------------------------------------
model Vente {
  id             Int          @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis       @relation(fields: [maquis_id], references: [id])
  caissier_id    Int
  caissier       Utilisateur  @relation(fields: [caissier_id], references: [id])
  date_vente     DateTime     @default(now())
  total_brut     Decimal      @db.Decimal(10, 2)
  remise_globale Decimal      @default(0) @db.Decimal(5, 2)
  total_net      Decimal      @db.Decimal(10, 2)
  mode_paiement  ModePaiement
  statut         StatutVente  @default(validee)
  valide_par     Int?
  note           String?      @db.Text
  lignes         VenteLigne[]
}

enum ModePaiement {
  especes
  wave
  orange_money
  mtn_money
  credit
  autre
}

enum StatutVente {
  validee
  annulee
  credit_en_cours
}

// ------------------------------------------------------------
// VENTE LIGNE
// ------------------------------------------------------------
model VenteLigne {
  id              Int     @id @default(autoincrement())
  vente_id        Int
  vente           Vente   @relation(fields: [vente_id], references: [id])
  produit_id      Int
  produit         Produit @relation(fields: [produit_id], references: [id])
  quantite        Decimal @db.Decimal(10, 3)
  prix_unitaire   Decimal @db.Decimal(10, 2)
  prix_catalogue  Decimal @db.Decimal(10, 2)
  economie_client Decimal @default(0) @db.Decimal(10, 2)
  remise_ligne    Decimal @default(0) @db.Decimal(5, 2)
  total_ligne     Decimal @db.Decimal(10, 2)
}

// ------------------------------------------------------------
// STOCK MOUVEMENT
// ------------------------------------------------------------
model StockMouvement {
  id             Int           @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis        @relation(fields: [maquis_id], references: [id])
  produit_id     Int
  produit        Produit       @relation(fields: [produit_id], references: [id])
  type_mouvement TypeMouvement
  quantite       Decimal       @db.Decimal(10, 3)
  raison         String?       @db.VarChar(255)
  utilisateur_id Int
  utilisateur    Utilisateur   @relation(fields: [utilisateur_id], references: [id])
  date_mouvement DateTime      @default(now())
  valide_par     Int?
  valide_at      DateTime?
  fournisseur_id Int?
  fournisseur    Fournisseur?  @relation(fields: [fournisseur_id], references: [id])
}

enum TypeMouvement {
  entree
  sortie_vente
  sortie_manuelle
  ajustement
}

// ------------------------------------------------------------
// INVENTAIRE
// ------------------------------------------------------------
model Inventaire {
  id          Int               @id @default(autoincrement())
  maquis_id   Int
  maquis      Maquis            @relation(fields: [maquis_id], references: [id])
  date_debut  DateTime          @default(now())
  date_fin    DateTime?
  statut      StatutInventaire  @default(en_cours)
  cree_par    Int
  cloture_par Int?
  lignes      InventaireLigne[]
}

enum StatutInventaire {
  en_cours
  cloture
}

// ------------------------------------------------------------
// INVENTAIRE LIGNE
// ------------------------------------------------------------
model InventaireLigne {
  id            Int        @id @default(autoincrement())
  inventaire_id Int
  inventaire    Inventaire @relation(fields: [inventaire_id], references: [id])
  produit_id    Int
  produit       Produit    @relation(fields: [produit_id], references: [id])
  qte_theorique Decimal    @db.Decimal(10, 3)
  qte_reelle    Decimal    @db.Decimal(10, 3)
  ecart         Decimal    @db.Decimal(10, 3)
}

// ------------------------------------------------------------
// LOG ACTION
// ------------------------------------------------------------
model LogAction {
  id             Int         @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis      @relation(fields: [maquis_id], references: [id])
  utilisateur_id Int
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id])
  type_action    String      @db.VarChar(80)
  description    String?     @db.Text
  date_action    DateTime    @default(now())
  ip_client      String?     @db.VarChar(45)
}

// ------------------------------------------------------------
// FOURNISSEUR
// ------------------------------------------------------------
model Fournisseur {
  id             Int              @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis           @relation(fields: [maquis_id], references: [id])
  nom            String           @db.VarChar(150)
  telephone      String?          @db.VarChar(20)
  email          String?          @db.VarChar(150)
  adresse        String?          @db.VarChar(255)
  actif          Boolean          @default(true)
  created_at     DateTime         @default(now())
  mouvements     StockMouvement[]
  bons_livraison BonLivraison[]
}

// ------------------------------------------------------------
// BON DE LIVRAISON
// ------------------------------------------------------------
model BonLivraison {
  id             Int                 @id @default(autoincrement())
  maquis_id      Int
  maquis         Maquis              @relation(fields: [maquis_id], references: [id])
  fournisseur_id Int?
  fournisseur    Fournisseur?        @relation(fields: [fournisseur_id], references: [id])
  date_livraison DateTime            @default(now())
  note           String?             @db.Text
  total_achat    Decimal             @db.Decimal(10, 2)
  cree_par       Int
  lignes         BonLivraisonLigne[]
}

// ------------------------------------------------------------
// BON DE LIVRAISON LIGNE
// ------------------------------------------------------------
model BonLivraisonLigne {
  id          Int          @id @default(autoincrement())
  bon_id      Int
  bon         BonLivraison @relation(fields: [bon_id], references: [id])
  produit_id  Int
  produit     Produit      @relation(fields: [produit_id], references: [id])
  quantite    Decimal      @db.Decimal(10, 3)
  prix_achat  Decimal      @db.Decimal(10, 2)
  total_ligne Decimal      @db.Decimal(10, 2)
}
